        // مرتب‌سازی درس‌ها
        Route::patch('lessons/reorder', [AdminLessonController::class, 'reorder']);


        // Route::apiResource('sections', CourseSectionController::class);

        // Route::apiResource('lessons', LessonController::class);

        // Route::delete(
