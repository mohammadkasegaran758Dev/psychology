class CourseAccessService
{
    /**
     * بررسی دسترسی کاربر به دوره
     */
    public function userHasAccess(?User $user, Course $course): bool
    {
        if ($course->is_free) {
            return true;
        }

        if (!$user || $user->status !== 'active') {
            return false;
        }

        if ($user->role === 'admin') {
            return true;
        }

        return $this->hasActiveEnrollment($user, $course);
