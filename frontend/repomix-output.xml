      <SidebarMenu>
        {adminNavItems.map((item) => {
          const hasSubItems = !!item.items?.length;
          const isParentActive =
            pathname === item.url || pathname.startsWith(item.url + "/");

          if (!hasSubItems) {
            return (
              <SidebarMenuItem key={item.title}>
